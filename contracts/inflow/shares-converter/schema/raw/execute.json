{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ExecuteMsg",
  "oneOf": [
    {
      "description": "User sends Neutron IBC shares and receives equal Cosmos Hub vault shares back.",
      "type": "object",
      "required": [
        "convert"
      ],
      "properties": {
        "convert": {
          "type": "object",
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    {
      "description": "Admin: register a new conversion pair (or update an existing one).",
      "type": "object",
      "required": [
        "add_pair"
      ],
      "properties": {
        "add_pair": {
          "type": "object",
          "required": [
            "cosmos_hub_shares_denom",
            "neutron_shares_denom"
          ],
          "properties": {
            "cosmos_hub_shares_denom": {
              "type": "string"
            },
            "neutron_shares_denom": {
              "type": "string"
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    {
      "description": "Admin: remove a conversion pair (e.g. once conversion window is closed).",
      "type": "object",
      "required": [
        "remove_pair"
      ],
      "properties": {
        "remove_pair": {
          "type": "object",
          "required": [
            "neutron_shares_denom"
          ],
          "properties": {
            "neutron_shares_denom": {
              "type": "string"
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    }
  ]
}
