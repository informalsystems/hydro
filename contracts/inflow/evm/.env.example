# Copy this file to .env and fill in the values.
# .env is gitignored — never commit it.

# ── Etherscan/Basescan verification ──────────────────────────────────────────
# Free API key from https://basescan.org/myapikey (works for any chain)
# ETHERSCAN_API_KEY=

# ── Signing key (one of these is required) ───────────────────────────────────

# MNEMONIC="word1 word2 word3 ... word24"
# PRIVATE_KEY=0x...

# ── deploy_inflow_vault.sh ───────────────────────────────────────────────────
# All of these have sensible Arc testnet defaults and can be omitted.

# ASSET=0x3600000000000000000000000000000000000000   # USDC on Arc testnet
# VAULT_NAME=inflow_usdc_share
# VAULT_SYMBOL=inflow_usdc_share
# DEPOSIT_CAP=1000000000000                          # 1 000 000 USDC (6 decimals)
# MAX_WITHDRAWALS_PER_USER=10
# INITIAL_ADMIN=                                     # defaults to deployer address
# FEE_RATE=0                                         # WAD; 0 = disabled, 1e17 = 10%
# FEE_RECIPIENT=                                     # required when FEE_RATE > 0

# ── deploy_basic_adapter.sh ──────────────────────────────────────────────────

# VAULT_ADDRESS=0x...       # proxy address printed by deploy_inflow_vault.sh
# ADAPTER_ADMIN=            # defaults to deployer address

# ── test_deposit_flow.sh ─────────────────────────────────────────────────────

# VAULT_ADDRESS=0x...       # same as above
# ADAPTER_ADDRESS=0x...     # proxy address printed by deploy_basic_adapter.sh
# DEPOSIT_AMOUNT=10000000   # raw units; 10_000_000 = 10 USDC (6 decimals)
# SKIP_REDEEM=false         # set to "true" to keep shares after deposit
