{
  "contract_name": "eureka-adapter",
  "contract_version": "3.6.11",
  "idl_version": "1.0.0",
  "instantiate": {
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "InstantiateMsg",
    "description": "Message for instantiating the Eureka adapter contract",
    "type": "object",
    "required": [
      "admins",
      "ibc_default_timeout_seconds",
      "initial_chains",
      "initial_depositors",
      "initial_executors",
      "initial_recover_addresses",
      "initial_tokens",
      "neutron_to_hub_channel",
      "skip_entry_point",
      "skip_ibc_adapter"
    ],
    "properties": {
      "admins": {
        "description": "Config admins who can manage chains, tokens, depositors, and executors",
        "type": "array",
        "items": {
          "type": "string"
        }
      },
      "ibc_default_timeout_seconds": {
        "description": "Default IBC timeout in seconds",
        "type": "integer",
        "format": "uint64",
        "minimum": 0.0
      },
      "initial_chains": {
        "description": "Initial chain configurations with allowed EVM destination addresses (can be empty)",
        "type": "array",
        "items": {
          "$ref": "#/definitions/InitialChainConfig"
        }
      },
      "initial_depositors": {
        "description": "Initial depositors (can be empty)",
        "type": "array",
        "items": {
          "$ref": "#/definitions/InitialDepositor"
        }
      },
      "initial_executors": {
        "description": "Initial executors who can perform TransferFunds (can be empty)",
        "type": "array",
        "items": {
          "$ref": "#/definitions/InitialExecutor"
        }
      },
      "initial_recover_addresses": {
        "description": "Initial allowed recover addresses on Cosmos Hub (can be empty)",
        "type": "array",
        "items": {
          "type": "string"
        }
      },
      "initial_tokens": {
        "description": "Initial tokens supported for bridging (can be empty)",
        "type": "array",
        "items": {
          "$ref": "#/definitions/TokenConfig"
        }
      },
      "neutron_to_hub_channel": {
        "description": "IBC channel from Neutron to Cosmos Hub (e.g. \"channel-1\")",
        "type": "string"
      },
      "skip_entry_point": {
        "description": "Skip swap entry point contract on Cosmos Hub",
        "type": "string"
      },
      "skip_ibc_adapter": {
        "description": "Skip swap IBC adapter contract on Cosmos Hub",
        "type": "string"
      }
    },
    "additionalProperties": false,
    "definitions": {
      "ChainConfig": {
        "description": "Chain configuration for a target EVM chain reachable via IBC Eureka",
        "type": "object",
        "required": [
          "chain_id",
          "eureka_fee_receiver",
          "eureka_source_channel",
          "max_eureka_fee",
          "min_eureka_fee"
        ],
        "properties": {
          "chain_id": {
            "description": "Internal chain identifier (e.g. \"ethereum-1\")",
            "type": "string"
          },
          "eureka_fee_receiver": {
            "description": "Cosmos Hub address that receives the Eureka relay fee",
            "type": "string"
          },
          "eureka_source_channel": {
            "description": "IBC Eureka source channel on Cosmos Hub to this EVM chain (e.g. \"08-wasm-1369\")",
            "type": "string"
          },
          "max_eureka_fee": {
            "description": "Maximum allowed Eureka fee amount (in the bridged token denom)",
            "allOf": [
              {
                "$ref": "#/definitions/Uint128"
              }
            ]
          },
          "min_eureka_fee": {
            "description": "Minimum allowed Eureka fee amount (in the bridged token denom)",
            "allOf": [
              {
                "$ref": "#/definitions/Uint128"
              }
            ]
          }
        },
        "additionalProperties": false
      },
      "DepositorCapabilities": {
        "description": "Depositor capabilities",
        "type": "object",
        "required": [
          "can_withdraw"
        ],
        "properties": {
          "can_withdraw": {
            "description": "Whether this depositor can withdraw funds from the adapter",
            "type": "boolean"
          }
        },
        "additionalProperties": false
      },
      "InitialChainConfig": {
        "description": "Initial chain configuration with allowed destination addresses",
        "type": "object",
        "required": [
          "chain_config",
          "initial_allowed_destination_addresses"
        ],
        "properties": {
          "chain_config": {
            "$ref": "#/definitions/ChainConfig"
          },
          "initial_allowed_destination_addresses": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "additionalProperties": false
      },
      "InitialDepositor": {
        "description": "Initial depositor configuration for instantiation",
        "type": "object",
        "required": [
          "address"
        ],
        "properties": {
          "address": {
            "type": "string"
          },
          "capabilities": {
            "description": "If not provided, defaults to { can_withdraw: true }",
            "anyOf": [
              {
                "$ref": "#/definitions/DepositorCapabilities"
              },
              {
                "type": "null"
              }
            ]
          }
        },
        "additionalProperties": false
      },
      "InitialExecutor": {
        "description": "Initial executor configuration for instantiation",
        "type": "object",
        "required": [
          "address"
        ],
        "properties": {
          "address": {
            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "TokenConfig": {
        "description": "Token configuration for a supported bridgeable token",
        "type": "object",
        "required": [
          "denom",
          "hub_denom"
        ],
        "properties": {
          "denom": {
            "description": "Token denom on Neutron (e.g. \"ibc/0E293...\")",
            "type": "string"
          },
          "hub_denom": {
            "description": "Same token's denom as seen on Cosmos Hub (used in eureka_fee.coin.denom)",
            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "Uint128": {
        "description": "A thin wrapper around u128 that is using strings for JSON encoding/decoding, such that the full u128 range can be used for clients that convert JSON numbers to floats, like JavaScript and jq.\n\n# Examples\n\nUse `from` to create instances of this and `u128` to get the value out:\n\n``` # use cosmwasm_std::Uint128; let a = Uint128::from(123u128); assert_eq!(a.u128(), 123);\n\nlet b = Uint128::from(42u64); assert_eq!(b.u128(), 42);\n\nlet c = Uint128::from(70u32); assert_eq!(c.u128(), 70); ```",
        "type": "string"
      }
    }
  },
  "execute": {
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "ExecuteMsg",
    "description": "Top-level execute message wrapper for Eureka adapter",
    "oneOf": [
      {
        "type": "object",
        "required": [
          "standard_action"
        ],
        "properties": {
          "standard_action": {
            "$ref": "#/definitions/AdapterInterfaceMsg"
          }
        },
        "additionalProperties": false
      },
      {
        "type": "object",
        "required": [
          "custom_action"
        ],
        "properties": {
          "custom_action": {
            "$ref": "#/definitions/EurekaAdapterMsg"
          }
        },
        "additionalProperties": false
      }
    ],
    "definitions": {
      "AdapterInterfaceMsg": {
        "description": "Standard execute messages that all protocol adapters must implement",
        "oneOf": [
          {
            "description": "Deposit tokens into the protocol Only callable by whitelisted depositors The coin is sent in info.funds",
            "type": "object",
            "required": [
              "deposit"
            ],
            "properties": {
              "deposit": {
                "type": "object",
                "additionalProperties": false
              }
            },
            "additionalProperties": false
          },
          {
            "description": "Withdraw tokens from the protocol Only callable by whitelisted depositors The execution MUST fail if insufficient funds are available",
            "type": "object",
            "required": [
              "withdraw"
            ],
            "properties": {
              "withdraw": {
                "type": "object",
                "required": [
                  "coin"
                ],
                "properties": {
                  "coin": {
                    "description": "Coin (denom + amount) to withdraw",
                    "allOf": [
                      {
                        "$ref": "#/definitions/Coin"
                      }
                    ]
                  }
                },
                "additionalProperties": false
              }
            },
            "additionalProperties": false
          },
          {
            "description": "Register new depositor address (admin only)",
            "type": "object",
            "required": [
              "register_depositor"
            ],
            "properties": {
              "register_depositor": {
                "type": "object",
                "required": [
                  "depositor_address"
                ],
                "properties": {
                  "depositor_address": {
                    "description": "New depositor address to register",
                    "type": "string"
                  },
                  "metadata": {
                    "description": "Optional adapter-specific metadata (e.g., capabilities) Serialized as Binary for flexibility",
                    "anyOf": [
                      {
                        "$ref": "#/definitions/Binary"
                      },
                      {
                        "type": "null"
                      }
                    ]
                  }
                },
                "additionalProperties": false
              }
            },
            "additionalProperties": false
          },
          {
            "description": "Unregister depositor address (admin only)",
            "type": "object",
            "required": [
              "unregister_depositor"
            ],
            "properties": {
              "unregister_depositor": {
                "type": "object",
                "required": [
                  "depositor_address"
                ],
                "properties": {
                  "depositor_address": {
                    "description": "Depositor address to unregister. The account should not have any funds deployed.",
                    "type": "string"
                  }
                },
                "additionalProperties": false
              }
            },
            "additionalProperties": false
          },
          {
            "description": "Toggle depositor address as enabled/disabled (admin only)",
            "type": "object",
            "required": [
              "set_depositor_enabled"
            ],
            "properties": {
              "set_depositor_enabled": {
                "type": "object",
                "required": [
                  "depositor_address",
                  "enabled"
                ],
                "properties": {
                  "depositor_address": {
                    "description": "Depositor address to enable or disable",
                    "type": "string"
                  },
                  "enabled": {
                    "type": "boolean"
                  }
                },
                "additionalProperties": false
              }
            },
            "additionalProperties": false
          },
          {
            "description": "Add a new admin (admin only)",
            "type": "object",
            "required": [
              "add_admin"
            ],
            "properties": {
              "add_admin": {
                "type": "object",
                "required": [
                  "admin_address"
                ],
                "properties": {
                  "admin_address": {
                    "type": "string"
                  }
                },
                "additionalProperties": false
              }
            },
            "additionalProperties": false
          },
          {
            "description": "Remove an admin (admin only)",
            "type": "object",
            "required": [
              "remove_admin"
            ],
            "properties": {
              "remove_admin": {
                "type": "object",
                "required": [
                  "admin_address"
                ],
                "properties": {
                  "admin_address": {
                    "type": "string"
                  }
                },
                "additionalProperties": false
              }
            },
            "additionalProperties": false
          }
        ]
      },
      "Binary": {
        "description": "Binary is a wrapper around Vec<u8> to add base64 de/serialization with serde. It also adds some helper methods to help encode inline.\n\nThis is only needed as serde-json-{core,wasm} has a horrible encoding for Vec<u8>. See also <https://github.com/CosmWasm/cosmwasm/blob/main/docs/MESSAGE_TYPES.md>.",
        "type": "string"
      },
      "ChainConfig": {
        "description": "Chain configuration for a target EVM chain reachable via IBC Eureka",
        "type": "object",
        "required": [
          "chain_id",
          "eureka_fee_receiver",
          "eureka_source_channel",
          "max_eureka_fee",
          "min_eureka_fee"
        ],
        "properties": {
          "chain_id": {
            "description": "Internal chain identifier (e.g. \"ethereum-1\")",
            "type": "string"
          },
          "eureka_fee_receiver": {
            "description": "Cosmos Hub address that receives the Eureka relay fee",
            "type": "string"
          },
          "eureka_source_channel": {
            "description": "IBC Eureka source channel on Cosmos Hub to this EVM chain (e.g. \"08-wasm-1369\")",
            "type": "string"
          },
          "max_eureka_fee": {
            "description": "Maximum allowed Eureka fee amount (in the bridged token denom)",
            "allOf": [
              {
                "$ref": "#/definitions/Uint128"
              }
            ]
          },
          "min_eureka_fee": {
            "description": "Minimum allowed Eureka fee amount (in the bridged token denom)",
            "allOf": [
              {
                "$ref": "#/definitions/Uint128"
              }
            ]
          }
        },
        "additionalProperties": false
      },
      "Coin": {
        "type": "object",
        "required": [
          "amount",
          "denom"
        ],
        "properties": {
          "amount": {
            "$ref": "#/definitions/Uint128"
          },
          "denom": {
            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "EurekaAdapterMsg": {
        "description": "Eureka adapter-specific execute messages",
        "oneOf": [
          {
            "description": "Transfer funds via IBC Eureka to an EVM chain (executor only)",
            "type": "object",
            "required": [
              "transfer_funds"
            ],
            "properties": {
              "transfer_funds": {
                "type": "object",
                "required": [
                  "instructions"
                ],
                "properties": {
                  "instructions": {
                    "$ref": "#/definitions/TransferFundsInstructions"
                  }
                },
                "additionalProperties": false
              }
            },
            "additionalProperties": false
          },
          {
            "description": "Update global contract configuration (admin only)",
            "type": "object",
            "required": [
              "update_config"
            ],
            "properties": {
              "update_config": {
                "type": "object",
                "required": [
                  "update"
                ],
                "properties": {
                  "update": {
                    "$ref": "#/definitions/UpdateConfigData"
                  }
                },
                "additionalProperties": false
              }
            },
            "additionalProperties": false
          },
          {
            "description": "Add a new executor (admin only)",
            "type": "object",
            "required": [
              "add_executor"
            ],
            "properties": {
              "add_executor": {
                "type": "object",
                "required": [
                  "executor_address"
                ],
                "properties": {
                  "executor_address": {
                    "type": "string"
                  }
                },
                "additionalProperties": false
              }
            },
            "additionalProperties": false
          },
          {
            "description": "Remove an executor (admin only)",
            "type": "object",
            "required": [
              "remove_executor"
            ],
            "properties": {
              "remove_executor": {
                "type": "object",
                "required": [
                  "executor_address"
                ],
                "properties": {
                  "executor_address": {
                    "type": "string"
                  }
                },
                "additionalProperties": false
              }
            },
            "additionalProperties": false
          },
          {
            "description": "Register a new EVM chain configuration (admin only)",
            "type": "object",
            "required": [
              "register_chain"
            ],
            "properties": {
              "register_chain": {
                "type": "object",
                "required": [
                  "chain_config"
                ],
                "properties": {
                  "chain_config": {
                    "$ref": "#/definitions/ChainConfig"
                  }
                },
                "additionalProperties": false
              }
            },
            "additionalProperties": false
          },
          {
            "description": "Update an existing chain configuration (admin only)",
            "type": "object",
            "required": [
              "update_registered_chain"
            ],
            "properties": {
              "update_registered_chain": {
                "type": "object",
                "required": [
                  "chain_config"
                ],
                "properties": {
                  "chain_config": {
                    "$ref": "#/definitions/ChainConfig"
                  }
                },
                "additionalProperties": false
              }
            },
            "additionalProperties": false
          },
          {
            "description": "Unregister a chain (admin only)",
            "type": "object",
            "required": [
              "unregister_chain"
            ],
            "properties": {
              "unregister_chain": {
                "type": "object",
                "required": [
                  "chain_id"
                ],
                "properties": {
                  "chain_id": {
                    "type": "string"
                  }
                },
                "additionalProperties": false
              }
            },
            "additionalProperties": false
          },
          {
            "description": "Register a token for bridging (admin only)",
            "type": "object",
            "required": [
              "register_token"
            ],
            "properties": {
              "register_token": {
                "type": "object",
                "required": [
                  "denom",
                  "hub_denom"
                ],
                "properties": {
                  "denom": {
                    "type": "string"
                  },
                  "hub_denom": {
                    "type": "string"
                  }
                },
                "additionalProperties": false
              }
            },
            "additionalProperties": false
          },
          {
            "description": "Unregister a token (admin only)",
            "type": "object",
            "required": [
              "unregister_token"
            ],
            "properties": {
              "unregister_token": {
                "type": "object",
                "required": [
                  "denom"
                ],
                "properties": {
                  "denom": {
                    "type": "string"
                  }
                },
                "additionalProperties": false
              }
            },
            "additionalProperties": false
          },
          {
            "description": "Add an allowed EVM destination address for a chain (admin only)",
            "type": "object",
            "required": [
              "add_allowed_destination_address"
            ],
            "properties": {
              "add_allowed_destination_address": {
                "type": "object",
                "required": [
                  "address",
                  "chain_id"
                ],
                "properties": {
                  "address": {
                    "type": "string"
                  },
                  "chain_id": {
                    "type": "string"
                  }
                },
                "additionalProperties": false
              }
            },
            "additionalProperties": false
          },
          {
            "description": "Remove an allowed EVM destination address (admin only)",
            "type": "object",
            "required": [
              "remove_allowed_destination_address"
            ],
            "properties": {
              "remove_allowed_destination_address": {
                "type": "object",
                "required": [
                  "address",
                  "chain_id"
                ],
                "properties": {
                  "address": {
                    "type": "string"
                  },
                  "chain_id": {
                    "type": "string"
                  }
                },
                "additionalProperties": false
              }
            },
            "additionalProperties": false
          },
          {
            "description": "Add an allowed Cosmos Hub recover address (admin only)",
            "type": "object",
            "required": [
              "add_allowed_recover_address"
            ],
            "properties": {
              "add_allowed_recover_address": {
                "type": "object",
                "required": [
                  "address"
                ],
                "properties": {
                  "address": {
                    "type": "string"
                  }
                },
                "additionalProperties": false
              }
            },
            "additionalProperties": false
          },
          {
            "description": "Remove an allowed recover address (admin only)",
            "type": "object",
            "required": [
              "remove_allowed_recover_address"
            ],
            "properties": {
              "remove_allowed_recover_address": {
                "type": "object",
                "required": [
                  "address"
                ],
                "properties": {
                  "address": {
                    "type": "string"
                  }
                },
                "additionalProperties": false
              }
            },
            "additionalProperties": false
          }
        ]
      },
      "TransferFundsInstructions": {
        "description": "Instructions for an Eureka bridge transfer",
        "type": "object",
        "required": [
          "amount",
          "chain_id",
          "denom",
          "recipient",
          "recover_address"
        ],
        "properties": {
          "amount": {
            "description": "Amount to bridge (excluding Eureka fee; fee is provided via info.funds)",
            "allOf": [
              {
                "$ref": "#/definitions/Uint128"
              }
            ]
          },
          "chain_id": {
            "description": "Target EVM chain ID from CHAIN_REGISTRY (e.g. \"ethereum-1\")",
            "type": "string"
          },
          "denom": {
            "description": "Token denom to bridge — must be registered in TOKEN_REGISTRY",
            "type": "string"
          },
          "recipient": {
            "description": "Recipient EVM address in hex format — validated against ALLOWED_DESTINATION_ADDRESSES",
            "type": "string"
          },
          "recover_address": {
            "description": "Cosmos Hub address to receive funds if the Eureka transfer fails — validated against ALLOWED_RECOVER_ADDRESSES",
            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "Uint128": {
        "description": "A thin wrapper around u128 that is using strings for JSON encoding/decoding, such that the full u128 range can be used for clients that convert JSON numbers to floats, like JavaScript and jq.\n\n# Examples\n\nUse `from` to create instances of this and `u128` to get the value out:\n\n``` # use cosmwasm_std::Uint128; let a = Uint128::from(123u128); assert_eq!(a.u128(), 123);\n\nlet b = Uint128::from(42u64); assert_eq!(b.u128(), 42);\n\nlet c = Uint128::from(70u32); assert_eq!(c.u128(), 70); ```",
        "type": "string"
      },
      "UpdateConfigData": {
        "description": "Data for updating the global contract config",
        "type": "object",
        "properties": {
          "ibc_default_timeout_seconds": {
            "type": [
              "integer",
              "null"
            ],
            "format": "uint64",
            "minimum": 0.0
          },
          "neutron_to_hub_channel": {
            "type": [
              "string",
              "null"
            ]
          },
          "skip_entry_point": {
            "type": [
              "string",
              "null"
            ]
          },
          "skip_ibc_adapter": {
            "type": [
              "string",
              "null"
            ]
          }
        },
        "additionalProperties": false
      }
    }
  },
  "query": {
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "QueryMsg",
    "description": "Top-level query message wrapper for Eureka adapter",
    "oneOf": [
      {
        "type": "object",
        "required": [
          "standard_query"
        ],
        "properties": {
          "standard_query": {
            "$ref": "#/definitions/AdapterInterfaceQueryMsg"
          }
        },
        "additionalProperties": false
      },
      {
        "type": "object",
        "required": [
          "custom_query"
        ],
        "properties": {
          "custom_query": {
            "$ref": "#/definitions/EurekaAdapterQueryMsg"
          }
        },
        "additionalProperties": false
      }
    ],
    "definitions": {
      "AdapterInterfaceQueryMsg": {
        "description": "Standard query messages that all protocol adapters should support Note: QueryResponses derive is handled by each adapter's QueryMsg wrapper",
        "oneOf": [
          {
            "description": "Returns the maximum amount that can be deposited Accounts for protocol deposit caps and other limitations",
            "type": "object",
            "required": [
              "available_for_deposit"
            ],
            "properties": {
              "available_for_deposit": {
                "type": "object",
                "required": [
                  "denom",
                  "depositor_address"
                ],
                "properties": {
                  "denom": {
                    "type": "string"
                  },
                  "depositor_address": {
                    "type": "string"
                  }
                },
                "additionalProperties": false
              }
            },
            "additionalProperties": false
          },
          {
            "description": "Returns the amount available for immediate withdrawal for a specific denom",
            "type": "object",
            "required": [
              "available_for_withdraw"
            ],
            "properties": {
              "available_for_withdraw": {
                "type": "object",
                "required": [
                  "denom",
                  "depositor_address"
                ],
                "properties": {
                  "denom": {
                    "type": "string"
                  },
                  "depositor_address": {
                    "type": "string"
                  }
                },
